# ============================================================
# SecondBrain Telegram Bot Configuration
# ============================================================
# 1. Copy this file to .env
# 2. Fill in your values below
# 3. The bot will auto-load .env on startup (if python-dotenv is installed)
#    or you can export the variables directly in your shell.
# ============================================================

# Required: Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required: Your Telegram numeric user ID.
# Only messages from this user will be processed.
# Find it via @userinfobot or @getidsbot on Telegram.
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id

# Optional: Local LLM provider. Use auto, ollama, or lmstudio.
SECONDBRAIN_LLM_PROVIDER=auto

# Optional: Local LLM server URL (default: Ollama on localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Model name served by Ollama (default: gemma4:e2b)
OLLAMA_MODEL=gemma4:e2b

# Optional: LM Studio OpenAI-compatible server and model.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=your-loaded-model-id

# Optional: Local/offline voice dictation via faster-whisper.
SECONDBRAIN_STT_ENGINE=faster-whisper
SECONDBRAIN_STT_MODEL=small
SECONDBRAIN_STT_DEVICE=cpu
SECONDBRAIN_STT_COMPUTE_TYPE=int8
SECONDBRAIN_STT_LANGUAGE=id
SECONDBRAIN_STT_MAX_SECONDS=60

# Optional: SecondBrain workspace directory (default: current directory)
SECONDBRAIN_WORKSPACE=.

# Optional: Web UI settings
SECONDBRAIN_UI_HOST=127.0.0.1
SECONDBRAIN_UI_PORT=3000

# Optional: SQL Server default profile.
# Keep the connection string local. Use the schema file to control what the LLM
# sees without dumping database metadata into chat history.
SECOND_BRAIN_SQL_DEFAULT_CONNECTION=Server=localhost;Database=YourDb;Trusted_Connection=yes;Encrypt=yes;TrustServerCertificate=yes
SECOND_BRAIN_SQL_DEFAULT_SCHEMA_FILE=sql_schema/default.md
