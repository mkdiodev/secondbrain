# ============================================================
# SecondBrain Telegram Bot Configuration
# ============================================================
# 1. Copy this file to .env
# 2. Fill in your values below
# 3. The bot will auto-load .env on startup (if python-dotenv is installed)
#    or you can export the variables directly in your shell.
# ============================================================

# Required: Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required: Your Telegram numeric user ID.
# Only messages from this user will be processed.
# Find it via @userinfobot or @getidsbot on Telegram.
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id

# Optional: Local LLM server URL (default: Ollama on localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Model name served by Ollama (default: gemma4:e2b)
OLLAMA_MODEL=gemma4:e2b

# Optional: SecondBrain workspace directory (default: current directory)
SECONDBRAIN_WORKSPACE=.
